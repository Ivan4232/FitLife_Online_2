---

const today = new Date();
const currentYear = today.getFullYear();

import {SITE_NAME} from '../../config';

---

<!-- Start Footer Section -->

<footer class="footer-section">
  <div class="container">
    <div class="footer-content">

      <!-- About -->
      <div class="discription">
        <img src="/assets/images/site-logo.png" alt="logo" />
        <p>Онлайн тренер. Помогаю похудеть, набрать массу и привести тело в форму без жёстких диет.</p>
        
        <!-- Social links -->
        <ul>
          <li class="title">Мы в соцсетях:</li>
          <li><a href="https://t.me/sophialesliwe"><i class="fa-brands fa-telegram"></i></a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="contact">
        <h3>Контакты</h3>
        <ul>
          <li>
            <a href="https://t.me/sophialesliwe">
              <i class="fa-brands fa-telegram"></i>sophialesliwe
            </a>
          </li>
        </ul>
      </div>

      <!-- CTA instead of newsletter -->
      <div class="letter">
        <h3>Хочешь результат?</h3>
        <p>Напиши мне в Telegram и получи план тренировок под себя.</p>
        
        <a href="https://t.me/sophialesliwe" class="btn">
          Написать в Telegram <i class="fa-solid fa-arrow-right"></i>
        </a>
      </div>

    </div>

    <!-- Bottom -->
    <p class="end-text">© {SITE_NAME} {currentYear} — Все права защищены</p>

  </div>
</footer>

<!-- End Footer Section -->
