---

<!-- Start Services Section -->

<section class="classes-section">
	<div class="container">
		<div class="top">
			<div class="section-title">
				<h4 class="subtitle"><span>FitLife Online</span></h4>
				<h1 class="title">Выбери формат и начни менять тело уже сейчас</h1>
			</div>
			<div class="button">
				<a href="#" class="btn">Написать в Telegram<i class="fa-solid fa-arrow-right"></i></a>
			</div>
		</div>

		<div class="main-accordion">

			<!-- Девочки -->
			<div class="accordion-header">
				<div class="class-title">
					<h3>Онлайн ведение для девушек</h3>
				</div>
				<div class="class-box">
					<div class="item">
						<span class="heading">Цена:</span>
						<span class="data">50$/мес</span>
					</div>
					<span class="separetor"></span>
					<div class="item">
						<span class="heading">Формат:</span>
						<span class="data">Онлайн</span>
					</div>
					<span class="separetor"></span>
					<div class="item">
						<span class="heading">Связь:</span>
						<span class="data">24/7</span>
					</div>
				</div>
				<div class="class-button">
					<a href="#"><i class="fa-solid fa-arrow-right"></i></a>
				</div>
			</div>

			<div class="accordion-content">
				<div class="content-box">
					<div class="content-left">
						<p>Полное сопровождение: тренировки, питание и контроль результата.</p>
						<p class="title">Что ты получишь:</p>
						<ul>
							<li>Индивидуальный план тренировок</li>
							<li>Питание без жёстких диет</li>
							<li>Расчёт БЖУ</li>
							<li>Контроль прогресса каждую неделю</li>
							<li>Поддержка и связь 24/7</li>
						</ul>
					</div>
					<div class="content-right">
						<img src="assets/images/class-img-01.jpg" alt="images">
					</div>
				</div>
			</div>

			<!-- Парни -->
			<div class="accordion-header">
				<div class="class-title">
					<h3>Онлайн ведение для парней</h3>
				</div>
				<div class="class-box">
					<div class="item">
						<span class="heading">Цена:</span>
						<span class="data">65$/мес</span>
					</div>
					<span class="separetor"></span>
					<div class="item">
						<span class="heading">Формат:</span>
						<span class="data">Онлайн</span>
					</div>
					<span class="separetor"></span>
					<div class="item">
						<span class="heading">Связь:</span>
						<span class="data">24/7</span>
					</div>
				</div>
				<div class="class-button">
					<a href="#"><i class="fa-solid fa-arrow-right"></i></a>
				</div>
			</div>

			<div class="accordion-content">
				<div class="content-box">
					<div class="content-left">
						<p>Программа под твою цель: масса, форма или сушка.</p>
						<p class="title">Что ты получишь:</p>
						<ul>
							<li>Индивидуальный план тренировок и питания</li>
							<li>Корректировка техники</li>
							<li>Постоянная обратная связь</li>
							<li>Учёт ограничений</li>
							<li>Контроль формы и прогресса</li>
						</ul>
					</div>
					<div class="content-right">
						<img src="assets/images/class-img-2.png" alt="images">
					</div>
				</div>
			</div>

			<!-- План тренировок -->
			<div class="accordion-header">
				<div class="class-title">
					<h3>План тренировок</h3>
				</div>
				<div class="class-box">
					<div class="item">
						<span class="heading">Цена:</span>
						<span class="data">20$</span>
					</div>
					<span class="separetor"></span>
					<div class="item">
						<span class="heading">Срок:</span>
						<span class="data">6 месяцев</span>
					</div>
					<span class="separetor"></span>
					<div class="item">
						<span class="heading">Формат:</span>
						<span class="data">PDF</span>
					</div>
				</div>
				<div class="class-button">
					<a href="#"><i class="fa-solid fa-arrow-right"></i></a>
				</div>
			</div>

			<div class="accordion-content">
				<div class="content-box">
					<div class="content-left">
						<p>Готовый план под твою цель и уровень.</p>
						<p class="title">Подходит для:</p>
						<ul>
							<li>Похудения</li>
							<li>Набора массы</li>
							<li>Улучшения формы</li>
						</ul>
					</div>
					<div class="content-right">
						<img src="assets/images/class-img-3.png" alt="images">
					</div>
				</div>
			</div>

			<!-- План питания -->
			<div class="accordion-header">
				<div class="class-title">
					<h3>План питания</h3>
				</div>
				<div class="class-box">
					<div class="item">
						<span class="heading">Цена:</span>
						<span class="data">20$</span>
					</div>
					<span class="separetor"></span>
					<div class="item">
						<span class="heading">Формат:</span>
						<span class="data">Индивидуально</span>
					</div>
					<span class="separetor"></span>
					<div class="item">
						<span class="heading">Диета:</span>
						<span class="data">Без жёстких ограничений</span>
					</div>
				</div>
				<div class="class-button">
					<a href="#"><i class="fa-solid fa-arrow-right"></i></a>
				</div>
			</div>

			<div class="accordion-content">
				<div class="content-box">
					<div class="content-left">
						<p>Питание, которое реально соблюдать.</p>
						<p class="title">Что внутри:</p>
						<ul>
							<li>Расчёт калорий и БЖУ</li>
							<li>Учёт вкусов</li>
							<li>Под твой режим дня</li>
							<li>Без срывов и жёстких диет</li>
						</ul>
					</div>
					<div class="content-right">
						<img src="assets/images/class-img-4.png" alt="images">
					</div>
				</div>
			</div>

		</div>
	</div>
</section>

<!-- End Services Section -->