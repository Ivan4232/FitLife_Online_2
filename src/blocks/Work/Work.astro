<!-- Start Work Process Section -->

<section class="work-process">
	<div class="container">

		<!-- Section Title -->
		<div class="section-title">
			<h4 class="subtitle"><span>HOW IT WORKS</span></h4> <!-- section subtitle -->
			<h1 class="title">Фитнес просто с FitLife Online</h1> <!-- section title -->
		</div>

		<div class="row">

			<!-- Step 1: Individual Plan -->
			<div class="col-md-6 col-xl-3">
				<div class="process-box">
					<div class="content-wrap">
						<div class="image">
							<div class="img-wrapper">
								<img src="assets/images/process-img1.png" alt="images">
							</div>
							<div class="process-icon">
								<img src="assets/images/icon-1.png" alt="icon">
							</div>
						</div>
						<div class="content">
							<h3 class="title">1. Индивидуальный план</h3> <!-- step title -->
							<p class="description">Персональная программа тренировок и питания под ваши цели и образ жизни.</p> <!-- step description -->
						</div>
					</div>
					<div class="number">01</div>
				</div>
			</div>

			<!-- Step 2: Daily Support -->
			<div class="col-md-6 col-xl-3">
				<div class="process-box even">
					<div class="content-wrap">
						<div class="image">
							<div class="img-wrapper">
								<img src="assets/images/process-img2.png" alt="images">
							</div>
							<div class="process-icon">
								<img src="assets/images/icon-2.png" alt="icon">
							</div>
						</div>
						<div class="content">
							<h3 class="title">2. Поддержка 24/7</h3> <!-- step title -->
							<p class="description">Связь и консультации через Telegram в любое время, исправление ошибок и мотивация.</p> <!-- step description -->
						</div>
					</div>
					<div class="number">02</div>
				</div>
			</div>

			<!-- Step 3: Weekly Progress Check -->
			<div class="col-md-6 col-xl-3">
				<div class="process-box">
					<div class="content-wrap">
						<div class="image">
							<div class="img-wrapper">
								<img src="assets/images/process-img3.png" alt="images">
							</div>
							<div class="process-icon">
								<img src="assets/images/icon-3.png" alt="icon">
							</div>
						</div>
						<div class="content">
							<h3 class="title">3. Контроль прогресса</h3> <!-- step title -->
							<p class="description">Еженедельные проверки и корректировки программы, чтобы держать результат на контроле.</p> <!-- step description -->
						</div>
					</div>
					<div class="number">03</div>
				</div>
			</div>

			<!-- Step 4: Real Results -->
			<div class="col-md-6 col-xl-3">
				<div class="process-box even">
					<div class="content-wrap">
						<div class="image">
							<div class="img-wrapper">
								<img src="assets/images/process-img4.png" alt="images">
							</div>
							<div class="process-icon">
								<img src="assets/images/icon-4.png" alt="icon">
							</div>
						</div>
						<div class="content">
							<h3 class="title">4. Результат</h3> <!-- step title -->
							<p class="description">Реальные изменения в теле и уверенность в своих достижениях.</p> <!-- step description -->
						</div>
					</div>
					<div class="number">04</div>
				</div>
			</div>

		</div>
	</div>

	<div class="shape-img">
		<img src="assets/images/work-line.png" alt="shape">
	</div>
</section>

<!-- End Work Process Section -->